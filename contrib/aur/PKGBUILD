# Contributor: Shyam Verma <ishyverma@gmail.com>

pkgname=vault-sync-bin
pkgver=0.1.0
pkgrel=1
pkgdesc="A fast, local-first note manager with multi-backend sync (Obsidian, Notion, Git)"
arch=('x86_64' 'aarch64')
url="https://vaultsync.dev"
license=('MIT')
depends=('glibc')
source_x86_64=("${pkgname}-${pkgver}-x86_64.tar.gz::https://github.com/ishyverma/vault-sync/releases/latest/download/vault-sync_Linux_x86_64.tar.gz")
source_aarch64=("${pkgname}-${pkgver}-aarch64.tar.gz::https://github.com/ishyverma/vault-sync/releases/latest/download/vault-sync_Linux_arm64.tar.gz")
sha256sums_x86_64=('SKIP')
sha256sums_aarch64=('SKIP')

package() {
  install -Dm755 vault "${pkgdir}/usr/bin/vault"
  install -Dm755 vaultd "${pkgdir}/usr/bin/vaultd"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
